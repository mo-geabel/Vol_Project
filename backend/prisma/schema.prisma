generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int     @id @default(autoincrement())
  name          String
  username      String  @unique
  password_hash String
  role              Role                @default(teacher)
  classes           Class[]
  teacher_attendances TeacherAttendance[] @relation("UserToTeacherAttendance")

  @@map("users")
}

model Student {
  id            Int          @id @default(autoincrement())
  name          String
  contact_info  String?
  parent_info   String?
  date_of_birth DateTime?
  enrollments   Enrollment[]

  @@map("students")
}

model Class {
  id                Int          @id @default(autoincrement())
  class_name        String
  type              ClassType
  teacher_id        Int?
  schedule_settings Json?
  teacher           User?        @relation(fields: [teacher_id], references: [id])
  enrollments       Enrollment[]
  schedules         Schedule[]
  theory_progress   TheoryProgress[]

  @@map("classes")
}

model Schedule {
  id               Int    @id @default(autoincrement())
  month_year       String
  weekend_config   Int[]
  manual_overrides Json?
  class_id         Int?
  class            Class? @relation(fields: [class_id], references: [id])

  @@map("schedules")
}

model Enrollment {
  id              Int              @id @default(autoincrement())
  student_id      Int
  class_id        Int
  status          EnrollmentStatus @default(Active)
  attendances     Attendance[]
  class           Class            @relation(fields: [class_id], references: [id])
  student         Student          @relation(fields: [student_id], references: [id])
  quran_progress  QuranProgress[]

  @@unique([student_id, class_id])
  @@map("enrollments")
}

model Attendance {
  id            Int              @id @default(autoincrement())
  enrollment_id Int
  date          DateTime         @db.Date
  status        AttendanceStatus
  enrollment    Enrollment       @relation(fields: [enrollment_id], references: [id])

  @@unique([enrollment_id, date])
  @@map("attendances")
}

model TeacherAttendance {
  id         Int              @id @default(autoincrement())
  teacher_id Int
  date       DateTime         @db.Date
  status     AttendanceStatus
  notes      String?
  teacher    User             @relation("UserToTeacherAttendance", fields: [teacher_id], references: [id])

  @@unique([teacher_id, date])
  @@map("teacher_attendance")
}

model QuranProgress {
  id            Int          @id @default(autoincrement())
  enrollment_id Int
  date          DateTime     @db.Date
  type          ProgressType
  surah_id      Int?
  start_verse   Int?
  end_verse     Int?
  rating        Int?
  enrollment    Enrollment   @relation(fields: [enrollment_id], references: [id])

  @@map("quran_progress")
}

model TheoryProgress {
  id            Int        @id @default(autoincrement())
  class_id      Int
  date          DateTime   @db.Date
  book_title    String
  topic_name    String
  pages_read    Int?
  notes         String?
  class         Class      @relation(fields: [class_id], references: [id])

  @@unique([class_id, date])
  @@map("theory_progress")
}

model QuranMetadata {
  surah_id    Int    @id
  surah_name  String
  verse_count Int

  @@map("quran_metadata")
}

model SystemSetting {
  key   String @id
  value Json

  @@map("system_settings")
}

enum Role {
  admin
  teacher
}

enum ClassType {
  Quran
  Theory
}

enum EnrollmentStatus {
  Active
  Disabled
}

enum AttendanceStatus {
  Present
  Absent
  Excused
}

enum ProgressType {
  Hifz
  Muraja
  NotPreparedHifz
  NotPreparedMuraja
}
